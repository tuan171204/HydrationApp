<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Quyền truy cập Internet để gọi OpenWeather API -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Quyền gửi notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Quyền dùng AlarmManager để lên lịch nhắc nhở -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- Quyền nhận broadcast khi máy khởi động (để restore alarm) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HydrationApp">

        <!-- MainActivity: màn hình chính -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- HistoryActivity: lịch sử uống nước -->
        <activity
            android:name=".activities.HistoryActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />

        <!-- ProfileActivity: hồ sơ người dùng -->
        <activity
            android:name=".activities.ProfileActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />

        <!-- StatsActivity: biểu đồ thống kê -->
        <activity
            android:name=".activities.StatsActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />

        <!--
            ReminderReceiver: BroadcastReceiver nhận alarm từ AlarmManager
            Đây là cách Android gửi notification - không hard-code giờ cố định
        -->
        <receiver
            android:name=".receivers.ReminderReceiver"
            android:exported="false" />

        <!--
            BootReceiver: Khôi phục alarm sau khi máy khởi động lại
            Vì AlarmManager bị xóa khi tắt máy
        -->
        <receiver
            android:name=".receivers.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
